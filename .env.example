################################################################################
# Shopify Store Configuration
################################################################################

# The internal Shopify domain of your store (used for Storefront API + checkout)
# Format: your-store-domain.myshopify.com
PUBLIC_STORE_DOMAIN=your-store-domain.myshopify.com

# Public storefront domain (used for SEO, canonical URLs, sitemaps, OG tags)
# Example: www.example.com
PUBLIC_STORE_FRONTEND_DOMAIN=www.example.com


################################################################################
# Storefront API Configuration
################################################################################

# Storefront ID (required for Hydrogen storefronts)
# Found in: Shopify Admin > Settings > Apps and sales channels > Hydrogen
PUBLIC_STOREFRONT_ID=storefront-id

# Storefront API version
# Format: YYYY-MM (pin this to avoid accidental breaking changes)
PUBLIC_STOREFRONT_API_VERSION=2024-10


################################################################################
# Storefront API Tokens
################################################################################

# PRIVATE Storefront API token (RECOMMENDED)
# Used for ALL server-side Storefront API requests
# Found in: Shopify Admin > Settings > Apps and sales channels
#            > Develop apps > [Your App] > API credentials
#
# ⚠️ NEVER expose this token to the client
PRIVATE_STOREFRONT_API_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# PUBLIC Storefront API token (OPTIONAL)
# Only required if you intentionally make client-side Storefront API calls
# Most storefronts DO NOT need this
PUBLIC_STOREFRONT_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


################################################################################
# Checkout Configuration
################################################################################

# Checkout domain (usually the same as the store domain)
# Used for redirects and checkout-related flows
PUBLIC_CHECKOUT_DOMAIN=store-name.myshopify.com


################################################################################
# Internationalization / Market Defaults
################################################################################

# Default locale used when no locale is present in the URL
# Example values: en-US, fr-FR, de-DE
PUBLIC_DEFAULT_LOCALE=en-US

# Default country/market
# Used for currency, pricing, and market-specific logic
PUBLIC_DEFAULT_COUNTRY=US


################################################################################
# Session & Security
################################################################################

# Session secret used to sign cookies and session data
# ⚠️ MUST be a long, random, unpredictable string
# ⚠️ NEVER commit the real value to version control
SESSION_SECRET=replace-with-a-long-random-secret


################################################################################
# Environment
################################################################################

# Application environment
# Used for dev-only routes, logging, and diagnostics
# Typical values: development | production
